
@{
    Layout = "_DevExtremeLayout";
    ViewData["Title"] = "";
    string nonceValue = Context.Items["CspNonce"].ToString();
}

<div class="row my-3">
    <div class="col">

        <div class="h-100 pt-4">

            <div class="row">
                <div class="col-xl-12">
                    <div class="card">
                        <div class="card-body pt-2">

                            <div class="row mb-2 pt-4 mb-4">
                                <div class="col">
                                    <h4 class="float-start my-2 mb-2">Document Category</h4>
                                </div>

                                <div class="col-2 d-flex justify-content-end">

                                    @{
                                        if (ViewData["sfInfo"].ToString().Substring(1, 1) != "0")
                                        {
                                            <button type="button" id="btn-New" class="btn btn-info align-self-start align-items-center" >
                                                <i class="ri-add-fill"></i> New
                                            </button>
                                        }
                                    }
               

                                </div>

                            </div>

                            <div class="mb-4">
                                <div class="row horizantalScrollContainer">
                                    <div class="col-12">
                                        <table id="dtList" class="table table-striped align-middle w-100">
                                            <thead>
                                                <tr class="bg-dark-subtle">
                                                    <th class="text-left">Type</th>
                                                    <th class="text-left">Category Number</th>
                                                    <th class="text-left">Code</th>
                                                    <th class="text-left">Description</th>
                                                    <th class="text-left" width="10%">Record Status</th>
                                                    <th class="text-center" width="20%">Action</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>


                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Maintenace -->
<div class="modal  fade" id="maintenaceModal" tabindex="-1" data-bs-backdrop="static" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog ">

        <form id="frmMaintenance" autocomplete="off">

            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="exampleModalLabel">Document Category Details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">

                    <div class="form-group mb-3">
                        <div class="col-12">
                            <label for="docCatNumber" class="form-label">Category Number <small id="lbCode" class="fst-italic ms-2 fs-6 fw-normal text-danger">Auto create upon saving.</small></label>
                        </div>
                        <div class="col">
                            <input type="text" class="form-control" name="docCatNumber" id="docCatNumber" readonly>
                        </div>
                    </div>

                    <div class="row">

                        <div class="col-6">
                            <div class="row">
                                <div class="form-group- mb-3">
                                    <div class="col-12">
                                        <label for="docType" class="form-label">Document Type</label>
                                    </div>
                                    <div class="col">
                                        <select class="form-select" id="docType">
                                            <option value="CS" selected> Cases </option>
                                            <option value="IS" > Issuance </option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-6 form-group mb-3">
                            <div class="col-3">
                                <label for="docCatCode" class="form-label">Code</label>
                            </div>
                            <div class="col">
                                <input type="text" class="form-control" min="3" max="4" name="docCatCode" id="docCatCode" autocomplete="off" maxlength="50" required>
                            </div>
                        </div>

                    </div>

                    <div class="form-group mb-3">
                        <div class="col-3">
                            <label for="docCatDesc" class="form-label">Description</label>
                        </div>
                        <div class="col">
                            <input type="text" class="form-control" name="docCatDesc" id="docCatDesc" autocomplete="off" maxlength="255" required>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <div class="col">
                            <div class="form-check mb-2">
                                <label class="form-check-label" for="recordStatus">Record Status</label>
                                <input class="form-check-input" type="checkbox" name="recordStatus" id="recordStatus" value="1">
                            </div>
                        </div>
                    </div>

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal"> <i class="ri-close-line me-1"></i> Close</button>
                    <button type="button" class="btn btn-success" id="btn-submit"> <i class="ri-save-line me-1"></i>Save</button>
                </div>
            </div>
        </form>
    </div>
</div>


<script nonce="@nonceValue">

    let sfInfo = '@ViewData["sfInfo"].ToString()';
    let dtTable;
    let frmMaintenance = $("#maintenaceModal");
    let baseData = { action: '', id: '' }

    $(() => {

        dtTable = $('#dtList').DataTable({
            columns: [
                { data: null },
                { data: "docCatNumber" },
                { data: "docCatCode" },
                { data: "docCatDesc" },
                { data: null },
                { data: null }
            ],
            paging: true,
            ordering: false,
            info: true,
            scrollX: false,
            scrollY: '50vh',
            columnDefs: [

                {
                    targets: [0],
                    width: '15%',
                    render: function (data, test, row, meta) {

                        // let prop = {
                         
                        //     text: 
                        // }
                        //     `<span class="fs-12 rounded-pill">${prop.text}</span>`

                        return data.docType === 'CS' ? 'Case' : 'Issuance';
                    }

                },
                {
                    targets: [4],
                    width: '15%',
                    className: 'text-center',
                    render: function (data, test, row, meta) {

                        let prop = {
                            badge: data.recordStatus ? 'bg-info' : 'bg-danger',
                            text: data.recordStatus ? 'Active' : 'Disabled'
                        }
                        return `<span class="fs-10 badge text-white ${prop.badge} rounded-pill">${prop.text}</span>`;
                    }

                },
                {
                    targets: [5],
                    width: '15%',
                    className: 'text-center',
                    render: function (data, test, row, meta) {


                        let html = `<div>
                                            ${sfInfo.substring(2, 3) == '1' ? `<button class="btn btn-sm btn-warning btn-icon waves-effect waves-light btn-update" title="Edit">
                                                                                    <i class="ri-edit-2-fill"></i>
                                                                                </button>` : ``}

                                            ${sfInfo.substring(3, 4) == '1' ? `<button class="btn btn-sm btn-danger btn-icon waves-effect waves-light btn-delete" title="Delete">
                                                                                    <i class="ri-delete-bin-2-fill"></i>
                                                                                </button>` : ``}

                                        </div>`;

                        return html;

                    }
                }
            ]
        })

        load_data();

        $('#btn-New').on('click', function () {
            baseData.action = 'C';
            baseData.id = '0';
            frmMaintenance.find('#docCatNumber').val("");
            frmMaintenance.find('#docCatCode').val('');
            frmMaintenance.find('#docCatDesc').val('');
            frmMaintenance.find('#recordStatus').prop('checked', true);
            $('#frmMaintenance')[0].reset();
            frmMaintenance.find('#lbCode').html('Auto create upon saving.');
            frmMaintenance.find("#btn-submit").html(' <i class="ri-save-line me-1"></i>Save');
            frmMaintenance.modal('show');
        })

        $('#dtList tbody').on('click', '.btn-update', function () {

            let data = dtTable.row($(this).closest('tr')).data()

            baseData.action = 'U';
            baseData.id = data.id;
            frmMaintenance.find('#docType').val(data.docType);
            frmMaintenance.find('#docCatNumber').val(data.docCatNumber);
            frmMaintenance.find('#docCatCode').val(data.docCatCode);
            frmMaintenance.find('#docCatDesc').val(data.docCatDesc);
            frmMaintenance.find('#recordStatus').prop('checked', data.recordStatus);
            frmMaintenance.find('#lbCode').html('');
            frmMaintenance.find("#btn-submit").html(' <i class="ri-save-line me-1"></i>Update');
            frmMaintenance.modal('show');
        })

        $('#dtList tbody').on('click', '.btn-delete', function () {

            let dr = dtTable.row($(this).closest('tr')).data()
            baseData.action = 'D';
            let data = {
                _action: baseData.action,
                id: dr.id,
                docCatNumber: dr.docCatNumber,
                docCatNumber: dr.docCatCode,
                docCatNumber: dr.docCatDesc,
                recordStatus: dr.recordStatus
            }

            Swal.fire({
                title: "Are you sure?",
                text: "You won't be able to revert this!",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#3085d6",
                cancelButtonColor: "#d33",
                confirmButtonText: "Yes, delete it!"
            }).then((result) => {
                if (result.isConfirmed) {
                    post_data(data);
                }
            });

        })

        $('#btn-submit').on('click', function () {

            let text = (baseData.action == 'C' ? 'Do you want to save new entry.' : 'Do you want to save changes.');
            let label = (baseData.action == 'C' ? 'Yes, save new entry.' : 'Yes, save changes.');

            if ($('#frmMaintenance')[0].reportValidity()) {

                Swal.fire({
                    title: "Are you sure?",
                    text: text,
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonColor: "#3085d6",
                    cancelButtonColor: "#d33",
                    confirmButtonText: label,
                }).then(function (result) {
                    if (result.isConfirmed) {

                        data = {
                            _action: baseData.action,
                            id: baseData.id,
                            docType: $('#docType').val(),
                            docCatNumber: $('#docCatNumber').val(),
                            docCatCode: $('#docCatCode').val(),
                            docCatDesc: $('#docCatDesc').val(),
                            recordStatus: $('#recordStatus').is(':checked')
                        }

                        post_data(data);

                    }
                });
            }
        });

    });


    function load_data() {

        getData("Library", "GET_DocumentCategory", { _action: 'A' }).done(function (data) {

            dtTable.rows().clear();
            dtTable.rows.add(data).draw();

        })

    }

    function post_data(data) {

        postData("Library", "POST_DocumentCategory", data).done(function (returnData) {

            let msg = returnData[0];

            if (!msg.includes("Success")) {

                Swal.fire({
                    icon: "error",
                    title: "ERROR!",
                    text: msg.replace("Msg: ", "")
                });
            }
            else {

                let componet = 'category';
                let text;

                if (baseData.action == 'C') {
                    text = `New ${componet} has been added`;
                }
                if (baseData.action == 'U') {
                    text = `Selected ${componet} has been updated`;
                }
                if (baseData.action == 'D') {
                    text = `Selected ${componet} has been deleted`;
                }

                frmMaintenance.modal('hide');

                Swal.fire({
                    title: "Success!",
                    text: text,
                    icon: "success",
                    // confirmButtonClass: "btn btn-primary w-xs mt-2",
                }).then(function (result) {
                    if (result.isConfirmed) {

                        load_data();
                    }
                });



            }

        })
    }


</script>