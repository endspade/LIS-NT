@using System.Data
@{
    Layout = "_DevExtremeLayout";
    ViewData["Title"] = "";
    string nonceValue = Context.Items["CspNonce"].ToString();
}

<div class="row pt-3">
    <div class="col-lg-12">
        <div class="card" id="orderList">

            <div class="card-header border-0">
                <div class="row align-items-center gy-3">
                    <div class="col-sm">
                        <h3 class="card-title mb-0">Case Document</h3>
                    </div>
                    <div class="col-sm-auto">
                        <div class="d-flex gap-1 flex-wrap">
                            @{
                                if (ViewData["sfInfo"].ToString().Substring(1, 1) != "0")
                                {               
                                    <button type="button" class="btn btn-primary align-self-start align-items-center" id="btn-New">
                                        <i class="ri-upload-2-line me-2"></i> Upload Document
                                    </button>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="card-body border border-dashed border-end-0 border-start-0 mb-3">
                <form>
                    <div class="row g-3">
                        <div class="col-xxl-5 col-sm-6">
                            <div class="search-box">
                                <input type="text" id="input_Search" class="form-control search" placeholder="Search something...">
                                <i class="ri-search-line search-icon"></i>
                            </div>
                        </div>
                        <!--end col-->
                        <div class="col-xxl-2 col-sm-6">
                            <div>
                                <input type="text" class="form-control flatpickr-input" data-provider="flatpickr" data-date-format="d M, Y" data-range-date="true" id="dateFilter" placeholder="Select date" readonly="readonly">
                            </div>
                        </div>
                        <!--end col-->
                        <div class="col-xxl-3 col-sm-6">
                            <div>
                                <select class="form-control select2" name="fcaseNumber" id="fcaseNumber" required>
                                </select>
                            </div>
                        </div>

                        <!--end col-->
                        <!--end col-->
                        <div class="col-xxl-1 col-sm-4">
                            <div>
                                <button type="button" class="btn btn-info w-100 btn-filter">
                                    <i class="ri-equalizer-fill me-1 align-bottom"></i>
                                    Filters
                                </button>
                            </div>
                        </div>
                        <!--end col-->
                    </div>
                    <!--end row-->
                </form>
            </div>

            <div class="card-body">
                <div class="mt-1">
                    <div class="table-responsive table-card mb-1">
                        <table id="dtList" class="table align-middle table-nowrap mb-0 w-100">
                            <thead>
                                <tr class="bg-dark-subtle text-uppercase">
                                    <th class="text-left" scope="col">Movement</th>
                                    <th class="text-left" scope="col">Case Number</th>
                                    <th class="text-left" scope="col">Case Title</th>
                                    <th class="text-left" scope="col">Incoming No.</th>
                                    <th class="text-left" scope="col">Outgoing No.</th>
                                    <th class="text-left" scope="col">Category</th>
                                    <th class="text-left" scope="col">Description</th>
                                    <th class="text-left" scope="col">Filename</th>
                                    <th class="text-left" scope="col">Date received</th>
                                    <th class="text-left" scope="col">Next Hiring</th>
                                    <th class="text-left" scope="col">Date Upload</th>
                                    <th class="text-center" scope="col">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="maintenaceModal" tabindex="-1" data-bs-backdrop="static" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-md">

        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">Case Document Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form id="frmMaintenance" autocomplete="off">

                <div class="modal-body">

                    <div class="col-12">
                        <div class="row">

                            <div class="col-12 mb-3">
                                <label for="caseType" class="form-label">Case number</label>
                                <div class="choices">
                                    <div class="">
                                        <select class="form-control select2" name="caseNumber" id="caseNumber" required>
                                            @foreach (DataRow dataRow in ((DataTable)ViewData["caseMaster"]).Rows)
                                            {
                                                <option value="@dataRow["DocNumber"].ToString()"> @dataRow["CaseNumber"].ToString().ToUpper() </option>
                                            }
                                        </select>
                                    </div>

                                </div>
                            </div>


                            <div class="form-group col-sm-12 col-md-6 mb-3">
                                <div class="col-12">
                                    <label for="incomingNo" class="form-label">Incoming Number </label>
                                </div>
                                <div class="col">
                                    <input type="text" class="form-control" name="incomingNo" id="incomingNo" autocomplete="off"  maxlength="50" required >
                                </div>
                            </div>


                            <div class="form-group col-sm-12 col-md-6 mb-3">
                                <div class="col-12">
                                    <label for="outgoingNo" class="form-label">Outgoing Number </label>
                                </div>
                                <div class="col">
                                    <input type="text" class="form-control" name="outgoingNo" id="outgoingNo" autocomplete="off"  maxlength="50" required>
                                </div>
                            </div>


                            <div class="col-12 mb-3">
                                <label for="docCategory" class="form-label">Document Category/Type</label>
                                <div class="choices">
                                    <div class="">
                                        <select class="form-control select2" name="docCategory" id="docCategory" autocomplete="off"   required>
                                        </select>
                                    </div>

                                </div>
                            </div>
                            <div class="form-group col-sm-12 mb-3">
                                <div class="col-12">
                                    <label for="petitioner" class="form-label">Petitioner </label>
                                </div>
                                <div class="col">
                                    <input type="text" class="form-control" name="petitioner" id="petitioner" autocomplete="off" maxlength="50" required>
                                </div>
                            </div>

                            <div class="form-group col-sm-12 mb-3">
                                <div class="col-12">
                                    <label for="judge" class="form-label">Judge </label>
                                </div>
                                <div class="col">
                                    <input type="text" class="form-control" name="judge" id="judge" autocomplete="off" maxlength="255"  required>
                                </div>
                            </div>

                            <div class="col-sm-12 col-md-6 form-group mb-3">
                                <div class="col-12">
                                    <label for="dateReceived" class="form-label">Date Received</label>
                                </div>
                                <div class="col">
                                    <input type="date" class="form-control" name="dateReceived" id="dateReceived" autocomplete="off" required>
                                </div>
                            </div>

                            <div class="col-sm-12 col-md-6 form-group mb-3">
                                <div class="col-12">
                                    <label for="dateNxtHiring" class="form-label">Next Hiring</label>
                                </div>
                                <div class="col">
                                    <input type="date" class="form-control" name="dateNxtHiring" id="dateNxtHiring" autocomplete="off" required>
                                </div>
                            </div>


                            <div class="col-12 form-group mb-3">
                                <div class="col-3">
                                    <label for="pendingIncident" class="form-label">Pending Incident</label>
                                </div>
                                <div class="col">
                                    <input type="text" class="form-control text-end" name="pendingIncident" id="pendingIncident" maxlength="50" autocomplete="off" required>
                                </div>
                            </div>

                            <div class="col-12 form-group mb-3">
                                <div>
                                    <label for="formFile" class="form-label">Attachment</label>
                                    <input class="form-control" type="file" id="formFile" required>
                                </div>
                            </div>

                            <div class="form-group col-auto mb-3">
                                <div class="">
                                    <div class="form-check mb-2">
                                        <label class="form-check-label" for="docIn">Incoming Document</label>
                                        <input class="form-check-input" type="checkbox" name="docIn" id="docIn" >
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>



                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal"> <i class="ri-close-line me-1"></i> Close</button>
                    <button type="button" class="btn btn-success" id="btn-submit"> <i class="ri-save-line me-1"></i>Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="frmPreviewModal" tabindex="-1" data-bs-backdrop="static" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="row">
                <div class="col-12">
                    <div id="frame-preview">
                        <iframe id="pdfFrame" src="" width="100%" style="min-height:100vh"></iframe>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>



<script nonce="@nonceValue">
    let sfInfo = '@ViewData["sfInfo"].ToString()';
    let dtTable;
    let frmMaintenance = $("#maintenaceModal");
    let frmPreview = $("#frmPreviewModal");
    let baseData = { action: '', id: '', docNumber: '', docGuid:'' }

    let dateFilter;
    var date = new Date();
    var firstDay = new Date(date.getFullYear(), date.getMonth(), 1);
    var lastDay = new Date(date.getFullYear(), date.getMonth() + 1, 0);

    $(() => {

        dateFilter = flatpickr('#dateFilter', {
            mode: "range",
            dateFormat: "Y-m-d",
            defaultDate: [firstDay, lastDay]
        })

        dtTable = $('#dtList').DataTable({
            columns: [
                { data: null },
                { data: "caseNumber" },
                { data: "caseTitle" },
                { data: "incomingNo" },
                { data: "outgoingNo" },
                { data: "docCatDesc" },
                { data: "documentDesc" },
                { data: "fileName" },
                { data: null },
                { data: null },
                { data: null },
                { data: null }
            ],
            paging: true,
            ordering: false,
            info: true,
            scrollX: true,
            scroller: true,
            scrollY: '50vh',
            searching: false,
            columnDefs: [
                {
                    targets: [0],
                    className: 'text-center',
                    orderable: false,
                    width: '10%',
                    render: function (data, test, row, meta) {

                        let prop= {
                            class: data.docIn ? `bg-success-subtle text-success`:`bg-danger-subtle text-danger`,
                            text: data.docIn ? `In` : `Out`,
                        }
                        return `<span class="badge ${prop.class} ">${prop.text}</span>`;

                    }

                },
                {
                    targets: [8],
                    className: 'text-center',
                    width: '10%',
                    render: function (data, test, row, meta) {

                        let tags = moment(data.dateReceived).format('YYYY-MMM-DD');
                        return tags;

                    }

                },
                {
                    targets: [9],
                    className: 'text-center',
                    width: '10%',
                    render: function (data, test, row, meta) {

                        let tags = moment(data.dateNxtHiring).format('YYYY-MMM-DD');
                        return tags;

                    }

                },
                {
                    targets: [10],
                    className: 'text-center',
                    width: '10%',
                    render: function (data, test, row, meta) {

                        let tags = moment(data.dateStamp).format('YYYY-MMM-DD');
                        return tags;

                    }

                },
                {
                    targets: [11],
                    width: '10%',
                    className: 'text-center',
                    render: function (data, test, row, meta) {


                        // let html = `<ul class="list-inline hstack gap-2 mb-0 justify-content-center">

                        //             ${sfInfo.substring(2, 3) == '1' ? `<li class="list-inline-item" title="Edit">
                        //                                                     <a class="text-primary d-inline-block edit-item-btn btn-update">
                        //                                                         <i class="ri-pencil-fill fs-16"></i>
                        //                                                     </a>
                        //                                                 </li>` : ``}

                        //             ${sfInfo.substring(2, 3) == '1' ? `<li class="list-inline-item"  title="Remove">
                        //                                                     <a class="text-danger d-inline-block remove-item-btn btn-delete">
                        //                                                         <i class="ri-delete-bin-5-fill fs-16"></i>
                        //                                                     </a>
                        //                                                 </li>` : ``}

                        //             </ul>`;


                        // return html
                        let html = `<div class="d-flex gap-3 justify-content-center">
                                                <div class="dropdown">
                                                    <button class="btn btn-light btn-icon btn-sm dropdown material-shadow-none " type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                                        <i class="ri-more-fill align-bottom"></i>
                                                    </button>
                                                    <ul class="dropdown-menu dropdown-menu-end" style="">
                                                        <li>
                                                            <a class="dropdown-item viewfile-list btn-preview" href="javascript:void(0)">View</a>
                                                        </li>
                                                        ${sfInfo.substring(2,3) == '1' ? `<li><a class="dropdown-item edit-list btn-update" href="javascript:void(0)" role="button">Edit</a></li>` : ``}
                                                       
                                                        ${sfInfo.substring(3,4) == '1' ? `
                                                        <li class="dropdown-divider"></li>
                                                        <li><a class="dropdown-item remove-list btn-delete" href="javascript:void(0)" role="button">Delete</a></li>` : ``}
                                                        
                                                        ${sfInfo.substring(4, 5) == '1' ? `
                                                        <li class="dropdown-divider"></li>
                                                        <li><a class="dropdown-item remove-list" href="@Url.Action("Preview", "Document")?strParam=${data.docGuid}" download=${data.fileName}>Download</a></li>` : ``}
                                                    </ul>
                                                </div>
                                            </div>`
                        return html

                    }

                },

            ]
        })

        $('#btn-New').on('click', function () {

            baseData.action = 'C';
            baseData.id = '0';
            frmMaintenance.find('#incomingNo').val('');
            frmMaintenance.find('#outgoingNo').val('');
            frmMaintenance.find('#petitioner').val('');
            frmMaintenance.find('#judge').val('');
            frmMaintenance.find('#dateReceived').val(moment().format('YYYY-MM-DD'));
            frmMaintenance.find('#dateNxtHiring').val(moment().add(30, 'days').format('YYYY-MM-DD'));
            frmMaintenance.find('#pendingIncident').val('');
            frmMaintenance.find('#docIn').prop('checked', true);
            frmMaintenance.find("#btn-submit").html(' <i class="ri-save-line me-1"></i>Save');
            $('#frmMaintenance')[0].reset();

            frmMaintenance.modal('show');
        })

        $('#dtList tbody').on('click', '.btn-preview', function () {

            let data = dtTable.row($(this).closest('tr')).data()
            frmPreview.find("#pdfFrame").attr(`src`, `@Url.Action("Preview", "Document")?strParam=${data.docGuid}#toolbar=0&navpanes=0&scrollbar=0`);
            frmPreview.modal('show');
        })

        $('#dtList tbody').on('click', '.btn-update', function () {

            let data = dtTable.row($(this).closest('tr')).data();

            baseData.action = 'U';
            baseData.id = data.id;
            baseData.docGuid = data.docGuid,
            frmMaintenance.find('#caseNumber').select2('trigger', 'select', { data: { id: data.docNumber, text: data.caseDesc } });
            frmMaintenance.find('#docCategory').select2('trigger', 'select', { data: { id: data.docCatCode, text: data.docCatDesc } });
            frmMaintenance.find('#incomingNo').val(data.incomingNo);
            frmMaintenance.find('#outgoingNo').val(data.outgoingNo);
            frmMaintenance.find('#petitioner').val(data.petitioner);
            frmMaintenance.find('#judge').val(data.judge);
            frmMaintenance.find('#dateReceived').val(moment(data.dateReceived).format('YYYY-MM-DD'));
            frmMaintenance.find('#dateNxtHiring').val(moment(data.dateNxtHiring).format('YYYY-MM-DD'));
            frmMaintenance.find('#pendingIncident').val(data.pendingIncident);
            frmMaintenance.find('#docIn').prop('checked', data.docIn);
            frmMaintenance.find("#btn-submit").html(' <i class="ri-save-line me-1"></i>Update');

            frmMaintenance.modal('show');
        })

        $('#dtList tbody').on('click', '.btn-delete', function () {

            let dr = dtTable.row($(this).closest('tr')).data()
            baseData.action = 'D';
            let data = {
                _action: baseData.action,
                id: dr.id,
                docGuid: baseData.docGuid,
                docNumber: dr.docNumber,
                caseNumber: dr.caseNumber,
                caseTitle: dr.caseTitle,
                caseDesc: dr.caseDesc,
                caseType: dr.caseType,
                caseLevel: dr.caseLevel,
                caseStatus: dr.caseStatus,
                caseNature: dr.caseNature,
                venue: dr.venue,
                amount: dr.amount,
                recordStatus: dr.recordStatus
            }

            Swal.fire({
                title: "Are you sure?",
                text: "You won't be able to revert this!",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#3085d6",
                cancelButtonColor: "#d33",
                confirmButtonText: "Yes, delete it!"
            }).then((result) => {
                if (result.isConfirmed) {
                    post_data(data);
                }
            });
        })

        $('#btn-submit').on('click', function () {

            let text = (baseData.action == 'C' ? 'Do you want to save new entry.' : 'Do you want to save changes.');
            let label = (baseData.action == 'C' ? 'Yes, save new entry.' : 'Yes, save changes.');

            if ($('#frmMaintenance')[0].reportValidity()) {

                Swal.fire({
                    title: "Are you sure?",
                    text: text,
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonColor: "#3085d6",
                    cancelButtonColor: "#d33",
                    confirmButtonText: label,
                }).then(function (result) {
                    if (result.isConfirmed) {

                        let formdata = new FormData();
                        formdata.append("_action", baseData.action);
                        formdata.append("id", baseData.id);
                        formdata.append("docNumber", $('#caseNumber').val());
                        formdata.append("docGuid", baseData.docGuid);
                        formdata.append("incomingNo", $('#incomingNo').val());
                        formdata.append("outgoingNo", $('#outgoingNo').val());
                        formdata.append("docCatCode", $('#docCategory').val());
                        formdata.append("docCatDesc", $('#docCategory option:selected').text());
                        formdata.append("petitioner", $('#petitioner').val());
                        formdata.append("judge", $('#judge').val());
                        formdata.append("handlingLawyer", $('#handlingLawyer').val());
                        formdata.append("dateReceived", $('#dateReceived').val());
                        formdata.append("dateNxtHiring", $('#dateNxtHiring').val());
                        formdata.append("pendingIncident", $('#pendingIncident').val());
                        formdata.append("docIn", $('#docIn').is(':checked'));
                        formdata.append("file", $("#formFile").prop('files')[0]);

                        post_data(formdata);

                    }
                });
            }
        });



        $('.select2').select2({
            dropdownParent: $('#maintenaceModal')
        });


        getData("Document", "GET_CaseMaster", {}).done(function (data) {

            let obj = null;

            obj = {
                results: $.map(data, function (item) {
                    return {
                        text: item.caseNumber,
                        id: item.docNumber,
                    }
                })
            }

            $('#fcaseNumber').html('').select2({ data: [{}] })
            $('#fcaseNumber').select2({
                theme: 'bootstrap-5',
                placeholder: 'Select case number',
                allowClear: true,
                data: obj.results
            })


        });

        getData("Library", "GET_DocumentCategory", { _action: 'ACS' }).done(function (data) {

            let obj = null;

            obj = {
                results: $.map(data, function (item) {
                    return {
                        text: item.docCatDesc,
                        id: item.docCatNumber,
                    }
                })
            }

            $('#docCategory').html('').select2({ data: [{}] })
            $('#docCategory').select2({
                dropdownParent: $('#maintenaceModal'),
                theme: 'bootstrap-5',
                placeholder: 'Select category',
                allowClear: true,
                data: obj.results
            })


        });



        load_data();

    });

    function load_data() {

        getData("Document", "GET_CaseDocument", { _action: 'A' }).done(function (data) {

            dtTable.rows().clear();
            dtTable.rows.add(data).draw();

        })

    }

    function post_data(data) {

        postFileData("Document", "POST_CaseDocument", data).done(function (returnData) {

            let msg = returnData[0];

            if (!msg.includes("Success")) {

                Swal.fire({
                    icon: "error",
                    title: "ERROR!",
                    text: msg.replace("Msg: ", "")
                });
            }
            else {


                let componet = 'case';
                let text;

                if (baseData.action == 'C') {
                    text = `New ${componet} has been added`;
                }
                if (baseData.action == 'U') {
                    text = `Selected ${componet} has been updated`;
                }
                if (baseData.action == 'D') {
                    text = `Selected ${componet} has been deleted`;
                }

                frmMaintenance.modal('hide');

                Swal.fire({
                    title: "Success!",
                    text: text,
                    icon: "success",
                    // confirmButtonClass: "btn btn-primary w-xs mt-2",
                }).then(function (result) {
                    if (result.isConfirmed) {

                        load_data();
                    }
                });



            }



        })
    }

</script>
