@{
    Layout = "_DevExtremeLayout";
    ViewData["Title"] = "";
    string nonceValue = Context.Items["CspNonce"].ToString();
}


<div class="row pt-3">
    <div class="col-lg-12">

        <div class="card">

            <div class="card-header border-0">
                <div class="row align-items-center gy-3">
                    <div class="col-sm">
                        <h3 class="card-title mb-0">Tax Matter</h3>
                    </div>
                    <div class="col-sm-auto">
                        <div class="d-flex gap-1 flex-wrap">
                            @{
                                if (ViewData["sfInfo"].ToString().Substring(1, 1) != "0")
                                {
                                        <button type="button" class="btn btn-primary align-self-start align-items-center" id="btn-New" @(ViewData["sfInfo"].ToString().Substring(1, 1) != "0" ? "" : "disabled")>
                                            <i class="ri-upload-2-line me-2"></i> Upload File
                                        </button>
                                }
                            }

                        </div>
                    </div>
                </div>
            </div>

            <div class="card-body border border-dashed border-end-0 border-start-0 mb-0 ">

                <div class="row g-3">

                    <div class="col-xxl-5 col-sm-6">
                        <div class="search-box">
                            <input type="text" id="input_Search" class="form-control search" placeholder="Search something...">
                            <i class="ri-search-line search-icon"></i>
                        </div>
                    </div>

                    <div class="col-xxl col-sm-4">
                        <div>
                            <select class="form-control select2" name="fprovCode" id="fprovCode" required>
                            </select>
                        </div>
                    </div>

                    <div class="col-xxl col-sm-4">
                        <div>
                            <select class="form-control select2" name="fmunCode" id="fmunCode" required>
                                <option></option>
                            </select>
                        </div>
                    </div>
                    <div class="col-xxl col-sm-4">
                        <div>
                            <select class="form-control select2" name="fbgyCode" id="fbgyCode" required>
                                <option></option>
                            </select>
                        </div>
                    </div>

                    <div class="col-xxl-1 col-sm-4">
                        <div>
                            <button type="button" class="btn btn-info w-100 btn-filter">
                                <i class="ri-equalizer-fill me-1 align-bottom"></i>
                                Filters
                            </button>
                        </div>
                    </div>

                </div>

            </div>

            <div class="card-body">
                <div class="mt-1">
                    <div class="table-responsive table-card mb-1">
                        <table id="dtList" class="table align-middle table-nowrap mb-0 w-100">
                            <thead>
                                <tr class="bg-dark-subtle text-uppercase">
                                    <th class="text-left" scope="col">File</th>
                                    <th class="text-left" scope="col">Description</th>
                                    <th class="text-left" scope="col">Remarks</th>
                                    <th class="text-left" scope="col">Province</th>
                                    <th class="text-left" scope="col">Municipality/City</th>
                                    <th class="text-left" scope="col">Barangay</th>
                                    <th class="text-center" scope="col">Action</th>
                                </tr>
                            </thead>
                            <tbody >
                            </tbody>
                        </table>
                    </div>
               
                </div>
            </div>

        </div>
    </div>
</div>




<div class="modal fade" id="maintenaceModal" tabindex="-1" data-bs-backdrop="static" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">

        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">RPT Document Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form id="frmMaintenance" autocomplete="off">

                <div class="modal-body">

                    <div class="col-12">
                        <div class="row">

                            <div class="col-sm-12 col-md-4 mb-3">
                                <label for="docCategory" class="form-label">Province</label>
                                <div class="choices">
                                    <div class="">
                                        <select class="form-control select2" name="provCode" id="provCode" required>
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <div class="col-sm-12 col-md-4 mb-3">
                                <label for="docCategory" class="form-label">Municipality/City</label>
                                <div class="choices">
                                    <div class="">
                                        <select class="form-control select2" name="munCode" id="munCode">
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <div class="col-sm-12 col-md-4 mb-3">
                                <label for="docCategory" class="form-label">Barangay</label>
                                <div class="choices">
                                    <div class="">
                                        <select class="form-control select2" name="bgyCode" id="bgyCode">
                                        </select>
                                    </div>
                                </div>
                            </div>


                            <div class="form-group col-sm-12 col-md-12 mb-3">
                                <div class="col-12">
                                    <label for="incomingNo" class="form-label">Description </label>
                                </div>
                                <div class="col">
                                    <input type="text" class="form-control" name="documentDesc" id="documentDesc" autocomplete="off" maxlength="255" required>
                                </div>
                            </div>

                            <div class="form-group col-sm-12 col-md-12 mb-3">

                                <div class="col-12">
                                    <label class="form-label">Remarks</label>
                                </div>
                                <div class="col">
                                    <textarea class="form-control" id="remarks" rows="5" autocomplete="off" maxlength="1080"></textarea>
                                </div>
                            </div>

                            <div class="col-12 form-group mb-3">
                                <div>
                                    <label for="formFile" class="form-label">Attachment</label>
                                    <input class="form-control" type="file" id="formFile" accept="application/pdf,application/vnd.ms-excel" required>
                                </div>
                            </div>

                            <div class="form-group col-auto mb-3">
                                <div class="">
                                    <div class="form-check mb-2">
                                        <label class="form-check-label" for="recordStatus">Record Status</label>
                                        <input class="form-check-input" type="checkbox" name="recordStatus" id="recordStatus">
                                    </div>
                                </div>
                            </div>


                        </div>
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal"> <i class="ri-close-line me-1"></i> Close</button>
                    <button type="button" class="btn btn-success" id="btn-submit"> <i class="ri-save-line me-1"></i>Save</button>
                </div>
            </form>
        </div>
    </div>
</div>


<div class="modal fade" id="frmPreviewModal" tabindex="-1" data-bs-backdrop="static" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
               <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
             <div class="row">
                <div class="col-12">
                    <div id="frame-preview">
                        <iframe id="pdfFrame" src="" width="100%" style="min-height:100vh"></iframe>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>




<script nonce="@nonceValue">

    let sfInfo = '@ViewData["sfInfo"].ToString()';
    let dtTable;
    let frmMaintenance = $("#maintenaceModal");
    let frmPreview = $("#frmPreviewModal");
    let baseData = { action: '', id: '', docGuid:'', docIn:true }
    let fPDCode = '';
    let pdCode = '';
    let onload = 1;

    $(() => {

        dtTable = $('#dtList').DataTable({
            columns: [
                { data: null },
                { data: 'documentDesc' },
                { data: 'remarks' },
                { data: 'provName' },
                { data: 'munName' },
                { data: 'bgyName' },
                { data: null }
            ],
            paging: true,
            ordering: false,
            info: false,
            scrollX: false,
            scrollY: '50vh',
            dom:'tip',
            language: tableOptions,
            columnDefs: [

                {
                    targets: [0],
                    render: function (data, test, row, meta) {

                        let tags = `<div class="d-flex align-items-center">
                                        
                                        <div class="flex-shrink-0 fs-17 me-2 filelist-icon">
                                            <i class="ri-file-pdf-fill align-bottom text-danger"></i>
                                        </div>
                                        
                                        <div class=" flex-grow-1">
                                            <h5 class="fs-14 mb-0"><a href="" class="text-body">${data.fileName}</a></h5>
                                        </div>
                                    </div>`;

                        return tags;
                    }

                },
                {
                    targets: [6],
                    width: '10%',
                    className: 'text-center',
                    render: function (data, test, row, meta) {


                        let tags = `<div class="d-flex gap-3 justify-content-center">
                                        <div class="dropdown">
                                            <button class="btn btn-light btn-icon btn-sm dropdown material-shadow-none " type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                                <i class="ri-more-fill align-bottom"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end" style="">
                                                <li>
                                                    <a class="dropdown-item viewfile-list btn-preview" href="javascript:void(0)">View</a>
                                                </li>

                                                ${sfInfo.substring(2, 3) == '1' ? `<li><a class="dropdown-item edit-list btn-update" href="javascript:void(0)" role="button">Edit</a></li>` : ``}

                                                ${sfInfo.substring(3, 4) == '1' ? `
                                                <li class="dropdown-divider"></li>
                                                <li><a class="dropdown-item remove-list btn-delete" href="javascript:void(0)" role="button">Delete</a></li>` : ``}

                                                ${sfInfo.substring(4, 5) == '1' ? `
                                                <li class="dropdown-divider"></li>
                                                <li><a class="dropdown-item remove-list" href="@Url.Action("Preview", "Document")?strParam=${data.docGuid}" download=${data.fileName}>Download</a></li>` : ``}

                                            </ul>
                                        </div>
                                    </div>`

                        return tags;

                    }
                }
            ]
        })

        $('#btn-New').on('click', function () {
            baseData.action = 'C';
            baseData.id = '';
            baseData.docGuid = '';
            // frmMaintenance.find('#documentDesc').val('');
            // frmMaintenance.find('#remarks').val('');
            // frmMaintenance.find('#recordStatus').prop('checked', true);
            $('#frmMaintenance')[0].reset();
            frmMaintenance.find("#btn-submit").html(' <i class="ri-save-line me-1"></i>Save');
            frmMaintenance.modal('show');
        })

        $('#dtList tbody').on('click', '.btn-preview', function () {

            let data = dtTable.row($(this).closest('tr')).data()
            frmPreview.find("#pdfFrame").attr(`src`, `@Url.Action("Preview", "Document")?strParam=${data.docGuid}#toolbar=0&navpanes=0&scrollbar=0`);
            frmPreview.modal('show');
        })

        $('#dtList tbody').on('click', '.btn-update', function () {

            let data = dtTable.row($(this).closest('tr')).data()

            baseData.action = 'U';
            baseData.id = data.id;
            baseData.docGuid = data.docGuid;
            frmMaintenance.find('#provCode').select2('trigger', 'select', { data: { id: data.provCode, text: data.provName}});
            frmMaintenance.find('#munCode').select2('trigger', 'select', { data: { id: data.munCode, text: data.munName } });
            frmMaintenance.find('#bgyCode').select2('trigger', 'select', { data: { id: data.bgyCode, text: data.bgyName } });
            frmMaintenance.find('#documentDesc').val(data.documentDesc);
            frmMaintenance.find('#remarks').val(data.remarks);
            frmMaintenance.find('#recordStatus').prop('checked', data.recordStatus);
            frmMaintenance.find("#btn-submit").html(' <i class="ri-save-line me-1"></i>Update');

            frmMaintenance.modal('show');
        })

        $('#dtList tbody').on('click', '.btn-delete', function () {

            let dr = dtTable.row($(this).closest('tr')).data()
            let formdata = new FormData();

            baseData.action = 'D';
            formdata.append("_action", baseData.action);
            formdata.append("id", dr.id);
            formdata.append("docIn", dr.docIn);
            formdata.append("docGuid", dr.docGuid);
            formdata.append("pdCode", dr.pdCode);
            formdata.append("documentDesc", dr.documentDesc);
            formdata.append("remarks", dr.remarks)
            formdata.append("recordStatus",dr.recordStatus)
            formdata.append("file", $("#formFile").prop('files')[0]);

            Swal.fire({
                title: "Are you sure?",
                text: "You won't be able to revert this!",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#3085d6",
                cancelButtonColor: "#d33",
                confirmButtonText: "Yes, delete it!"
            }).then((result) => {
                if (result.isConfirmed) {
                    post_data(formdata);
                }
            });
        })

        $('#btn-submit').on('click', function () {

            let text = (baseData.action == 'C' ? 'Do you want to save new entry.' : 'Do you want to save changes.');
            let label = (baseData.action == 'C' ? 'Yes, save new entry.' : 'Yes, save changes.');

            if ($('#frmMaintenance')[0].reportValidity()) {

                Swal.fire({
                    title: "Are you sure?",
                    text: text,
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonColor: "#3085d6",
                    cancelButtonColor: "#d33",
                    confirmButtonText: label,
                }).then(function (result) {
                    
                    let vmunCode = $('#munCode').val();
                    let vbgyCode = $('#bgyCode').val();

                    if (result.isConfirmed) {

                        let formdata = new FormData();
                        formdata.append("_action", baseData.action);
                        formdata.append("id", baseData.id);
                        formdata.append("docIn", true);
                        formdata.append("docGuid", baseData.docGuid);
                        formdata.append("provCode",$('#provCode').val());
                        formdata.append("munCode", vmunCode.length == 0 ? '00' : vmunCode);
                        formdata.append("bgyCode", vbgyCode.length == 0 ? '000' : vbgyCode);
                        formdata.append("documentDesc", $('#documentDesc').val());
                        formdata.append("remarks", $('#remarks').val());
                        formdata.append("recordStatus", $('#recordStatus').is(':checked'));
                        formdata.append("file", $("#formFile").prop('files')[0]);

                        post_data(formdata);

                    }
                });
            }
        });



        $('#input_Search').keyup(function () {

            dtTable.search($(this).val()).draw();
        })

        load_fltr_Prv();
        load_Prv();
        load_data({ _action: '' });

    });


    function load_data(data) {

        getData("Document", "GET_TaxMatter", data).done(function (data) {

            dtTable.rows().clear();
            dtTable.rows.add(data).draw();
            onload = 0;

        })

    }

    function post_data(data) {

        postFileData("Document", "POST_TaxMatter", data).done(function (returnData) {

            let msg = returnData[0];

            if (!msg.includes("Success")) {

                Swal.fire({
                    icon: "error",
                    title: "ERROR!",
                    text: msg.replace("Msg: ", "")
                });
            }
            else {

                let componet = 'RPT';
                let text;

                if (baseData.action == 'C') {
                    text = `New ${componet} has been Uploaded`;
                }
                if (baseData.action == 'U') {
                    text = `Selected ${componet} has been updated`;
                }
                if (baseData.action == 'D') {
                    text = `Selected ${componet} has been deleted`;
                }

                frmMaintenance.modal('hide');

                Swal.fire({
                    title: "Success!",
                    text: text,
                    icon: "success",
                    // confirmButtonClass: "btn btn-primary w-xs mt-2",
                }).then(function (result) {
                    if (result.isConfirmed) {

                        load_data();
                    }
                });



            }



        })
    }

    //FILTER SELECTION
    function load_fltr_Prv() {

        getData("PhilDemographic", "GET_PSG", { _action: 'PRV' }).done(function (data) {

            let obj = [];

            obj = {
                results: $.map(data, function (item) {
                    return {
                        text: item.pdName,
                        id: item.pdCode,
                    }
                })
            }

            $('#fprovCode').select2({
                theme: 'bootstrap-5',
                data: obj.results
            })

            $('#fprovCode').trigger('change');
        })

    }

    $('#fprovCode').on('change', function () {

        let code = $(this).val();
      
        let param = {
            _action:'MUN',
            provCode: code.substring(2, 5),
            munCode:''
        }

        getData("PhilDemographic", "GET_PSG", param).done(function (data) {

            let obj = null;

            obj = {
                results: $.map(data, function (item) {
                    return {
                        text: item.pdName,
                        id: item.munCode,
                    }
                })
            }

            $('#fmunCode').html('').select2({ data: [{}] })
            $('#fmunCode').select2({
                theme: 'bootstrap-5',
                placeholder: 'Select municipality',
                allowClear: true,
                data: obj.results
            })

        })

        $('#fmunCode').trigger('change');

    })

    $('#fmunCode').on('change', function () {

        let code = $('#fprovCode').val();
        let param = {
            _action: 'BGY',
            provCode: code.substring(2, 5),
            munCode: $('#fmunCode').val()
        }

        getData("PhilDemographic", "GET_PSG", param).done(function (data) {

            let obj = null;

            obj = {
                results: $.map(data, function (item) {
                    return {
                        text: item.pdName,
                        id: item.bgyCode,
                    }
                })
            }

            $('#fbgyCode').html('').select2({ data: [{}] })
            $('#fbgyCode').select2({
                theme: 'bootstrap-5',
                placeholder: 'Select barangay',
                allowClear: true,
                data: obj.results
            })


        })

        $('#fbgyCode').trigger('change');

    })

    $('.btn-filter').on('click', function () {
        
        // let code = $('#fprovCode').val();
        // let mcode = ($('#fmunCode').val() == '' ? '00' : $('#fmunCode').val());
        // let bcode = ($('#fbgyCode').val() == '' ? '000' : $('#fbgyCode').val());

        let param = {

            _action:'',
            provCode: $('#fprovCode').val(),
            munCode: $('#fmunCode').val(),
            bgyCode: $('#fbgyCode').val()
        }

        load_data(param);
    })



    //ENTRY SELECTION

    function load_Prv() {

        getData("PhilDemographic", "GET_PSG", { _action: 'PRV' }).done(function (data) {

            let obj = [];

            obj = {
                results: $.map(data, function (item) {
                    return {
                        text: item.pdName,
                        id: item.pdCode,
                    }
                })
            }

            $('#provCode').select2({
                dropdownParent: $('#maintenaceModal'),
                theme: 'bootstrap-5',
                data: obj.results
            })

            $('#provCode').trigger('change');
        })

    }

    $('#provCode').on('change', function () {

        let code = $(this).val();

        let param = {
            _action: 'MUN',
            provCode: code.substring(2, 5),
            munCode: ''
        }

        getData("PhilDemographic", "GET_PSG", param).done(function (data) {

            let obj = null;

            obj = {
                results: $.map(data, function (item) {
                    return {
                        text: item.pdName,
                        id: item.munCode,
                    }
                })
            }

            $('#munCode').html('').select2({ data: [{}] })
            $('#munCode').select2({
                dropdownParent: $('#maintenaceModal'),
                theme: 'bootstrap-5',
                placeholder: 'Select municipality',
                allowClear: true,
                data: obj.results
            })

        })

        $('#munCode').trigger('change');

    })

    $('#munCode').on('change', function () {

        let code = $('#provCode').val();
        let param = {
            _action: 'BGY',
            provCode: code.substring(2, 5),
            munCode: $('#munCode').val()
        }

        getData("PhilDemographic", "GET_PSG", param).done(function (data) {

            let obj = null;

            obj = {
                results: $.map(data, function (item) {
                    return {
                        text: item.pdName,
                        id: item.pdCode,
                    }
                })
            }

            $('#bgyCode').html('').select2({ data: [{}] })
            $('#bgyCode').select2({
                dropdownParent: $('#maintenaceModal'),
                theme: 'bootstrap-5',
                placeholder: 'Select barangay',
                allowClear: true,
                data: obj.results
            })


        })

        $('#bgyCode').trigger('change');

    })






</script>