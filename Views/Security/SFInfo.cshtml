@using System.Data
@{
    Layout = "_DevExtremeLayout";
    ViewData["Title"] = "";
    string nonceValue = Context.Items["CspNonce"].ToString();
}

<div class="row my-3">
    <div class="col">

        <div class="h-100 pt-4">

            <div class="row">
                <div class="col-xl-12">
                    <div class="card">
                        <div class="card-body pt-2">

                            <div class="row mb-2 pt-4 mb-4">
                                <div class="col">
                                    <h4 class="float-start my-2 mb-2">Access Role</h4>
                                </div>
                            </div>

                            <div class="col-4">
                                <div class="row">
                                    <div class="form-group- mb-3">
                                        <div class="col-12">
                                            <label for="rbacCode" class="form-label">RBAC Group</label>
                                        </div>
                                        <div class="col">
                                            <select class="form-select" id="rbacCode">
                                                @foreach (DataRow dataRow in ((DataTable)ViewData["RBACGroup"]).Rows)
                                                {
                                                    <option value="@dataRow["RBACCode"].ToString()"> @dataRow["RBACDesc"].ToString().ToUpper() </option>
                                                }
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="mb-4">
                                <div class="row horizantalScrollContainer">
                                    <div class="col-12">
                                        <table id="dtList" class="table table-striped align-middle w-100">
                                            <thead>
                                                <tr class="bg-dark-subtle">
                                                    <th class="text-left">Module</th>
                                                    <th class="text-center">View</th>
                                                    <th class="text-center">Create</th>
                                                    <th class="text-center">Update</th>
                                                    <th class="text-center">Delete</th>
                                                    <th class="text-center">Download</th>
                                                    <th class="text-center">Action</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>



<script nonce="@nonceValue">

    let sfInfo = '@ViewData["sfInfo"].ToString()';
    let dtTable;
    let frmMaintenance = $("#maintenaceModal");
    let baseData = { action: '', id: '' }

    $(() => {

        dtTable = $('#dtList').DataTable({
            columns: [
                { data: "moduleDesc" },
                { data: null },
                { data: null },
                { data: null },
                { data: null },
                { data: null },
                { data: null }
            ],
            paging: true,
            ordering: false,
            info: true,
            scrollX: false,
            scrollY: '40vh',
            columnDefs: [
                {
                    targets: [0],
                    width: '40%'
                },
                {
                    targets: [1],
                    render: function (data, test, row, meta) {

                        let checked = data.sfInfo.substring(0, 1) == 1 ? 'checked' : ''

                        return `<div class="form-check text-center">
                                        <input class="form-check-input" type="checkbox" name="sfinfo" clm="0" ${checked}>
                                    </div>`;

                    }

                },
                {
                    targets: [2],
                    with: '10%',
                    render: function (data, test, row, meta) {

                        let checked = data.sfInfo.substring(1, 2) == 1 ? 'checked' : ''
                        return `<div class="form-check text-center">
                                        <input class="form-check-input" type="checkbox" name="sfinfo" ${checked}>
                                    </div>`;

                    }

                },
                {
                    targets: [3],
                    with: '10%',
                    render: function (data, test, row, meta) {

                        let checked = data.sfInfo.substring(2, 3) == 1 ? 'checked' : ''
                        return `<div class="form-check text-center">
                                        <input class="form-check-input" type="checkbox" name="sfinfo"  ${checked}>
                                    </div>`;

                    }

                },
                {
                    targets: [4],
                    with: '10%',
                    render: function (data, test, row, meta) {
                        let checked = data.sfInfo.substring(3, 4) == 1 ? 'checked' : ''
                        return `<div class="form-check text-center">
                                        <input class="form-check-input" type="checkbox" name="sfinfo" ${checked}>
                                    </div>`;

                    }

                },
                {
                    targets: [5],
                    with: '10px',
                    render: function (data, test, row, meta) {
                        let checked = data.sfInfo.substring(4, 5) == 1 ? 'checked' : ''
                        return `<div class="form-check text-center">
                                        <input class="form-check-input" type="checkbox" name="sfinfo" ${checked}>
                                    </div>`;

                    }

                },
                {
                    targets: [6],
                    with: '10%',
                    render: function (data, test, row, meta) {
                        let checked = data.sfInfo.substring(5, 6) == 1 ? 'checked' : ''
                        return `<div class="form-check text-center">
                                        <input class="form-check-input" type="checkbox" name="checkall" id="checkAll" ${checked}>
                                        <small>Check All</small>
                                    </div>`

                    }

                },

            ]
        })

        load_data();

        $('#dtList tbody').on('change', 'input[name="sfinfo"]', function () {

            let data = dtTable.row($(this).closest('tr')).data()
            let param = {
                id: data.id,
                rbacCode: data.rbacCode,
                moduleCode: data.moduleCode,
                sfInfo: ''
            }

            $.each($(this).closest('tr').find('input[type="checkbox"]'), function (i, v) {

                param.sfInfo = param.sfInfo + `${$(v).is(':checked') ? 1 : 0}`;
            })

            post_data(param);

        })

        $('#dtList tbody').on('change', '#checkAll', function () {

            let data = dtTable.row($(this).closest('tr')).data()
            let chckall = $(this).closest('tr').find('input[name="checkall"]').is(':checked');
            let param = {
                id: data.id,
                rbacCode: data.rbacCode,
                moduleCode: data.moduleCode,
                sfInfo: ''
            }

            $.each($(this).closest('tr').find('input[type="checkbox"]'), function (i, v) {

                $(v).prop('checked', chckall)
                param.sfInfo = param.sfInfo + `${$(v).is(':checked') ? 1 : 0}`;
            })

            post_data(param)

        })


        $('#rbacCode').on('change', function () {
            load_data();
        })
    });



    function load_data() {

        getData("Security", "GET_SFInfo", { rbacCode: $('#rbacCode').val() }).done(function (data) {
            dtTable.rows().clear();
            dtTable.rows.add(data).draw();
        })

    }

    function post_data(param) {

        postData("Security", "POST_SFInfo", param).done(function (data) {

            let msg = data[0];

            if (!msg.includes("Success")) {

                swal("ERROR!", msg.replace("Msg: ", ""), "error");
            }
            else {

            }
        })
    }


</script>